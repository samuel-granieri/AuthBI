@model List<Dictionary<string, object?>>

@if (Model == null || !Model.Any())
{
    <p style="color: var(--bs-secondary); padding: 1rem;">Nenhum resultado encontrado.</p>
}
else
{
    <div style="overflow-x: auto; border-radius: 8px; border: 1px solid #dee2e6;">
        <table style="width: 100%; border-collapse: collapse; font-size: 14px;">
            <thead>
                <tr style="background: #f8f9fa; border-bottom: 2px solid #dee2e6;">
                    @foreach (var col in Model.First().Keys)
                    {
                        <th style="padding: 10px 16px; text-align: left; font-weight: 600; color: #495057; white-space: nowrap;">
                            @col
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var (row, index) in Model.Select((r, i) => (r, i)))
                {
                    <tr style="border-bottom: 1px solid #f1f3f5; background: @(index % 2 == 0 ? "#ffffff" : "#f8f9fa");">
                        @foreach (var val in row.Values)
                        {
                            <td style="padding: 10px 16px; color: #212529; white-space: nowrap;">
                                @val
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <p style="font-size: 12px; color: #868e96; margin-top: 8px;">
        @Model.Count resultado(s)
    </p>
}